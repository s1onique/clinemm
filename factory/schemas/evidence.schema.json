{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://cline--.local/schemas/evidence.schema.json",
  "title": "Detached Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "act_id", "head_oid", "tree_oid", "generated_at", "commands", "hashes"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "act_id": { "type": "string" },
    "head_oid": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "tree_oid": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "host_arch": { "type": "string" },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "started_at", "finished_at", "duration_ms", "exit_code", "signal", "timeout", "stdout_sha256", "stderr_sha256", "head_oid", "tree_oid", "environment_sha256"],
        "properties": {
          "id": { "type": "string" },
          "status": { "enum": ["pass", "fail", "skip", "unavailable", "not-run"] },
          "started_at": { "type": "string", "format": "date-time" },
          "finished_at": { "type": "string", "format": "date-time" },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "exit_code": { "type": ["integer", "null"] },
          "signal": { "type": ["string", "null"] },
          "timeout": { "type": "boolean" },
          "stdout_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "stderr_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "stdout_path": { "type": "string" },
          "stderr_path": { "type": "string" },
          "head_oid": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "tree_oid": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "environment_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "failure_classification": { "enum": ["FORK-INTRODUCED", "UPSTREAM-REPRODUCIBLE", "ENVIRONMENTAL", "CREDENTIAL-REQUIRED", "NETWORK-DEPENDENT", "HOST-UNSUPPORTED", "NONDETERMINISTIC", "UNKNOWN"] },
          "notes": { "type": "string" }
        }
      }
    },
    "hashes": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    }
  }
}