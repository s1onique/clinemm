{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://cline--.local/schemas/environment.schema.json",
  "title": "Environment Proof",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "timestamp",
    "os",
    "kernel",
    "architecture",
    "process_architecture",
    "bun_architecture",
    "node_architecture",
    "rosetta_translated",
    "cpu",
    "logical_cpus",
    "memory_bytes",
    "fs_case_sensitive",
    "git_version",
    "git_lfs_version",
    "bun_version",
    "bun_revision",
    "node_version",
    "npm_version",
    "vscode_version",
    "vscode_architecture",
    "xcode_path",
    "xcode_version",
    "python_version",
    "clang_version",
    "shell",
    "locale",
    "timezone",
    "proxy_variable_names",
    "ci_indicator",
    "native_assertions"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "os": { "type": "object", "additionalProperties": false, "required": ["name", "version", "build"], "properties": { "name": { "type": "string" }, "version": { "type": "string" }, "build": { "type": "string" } } },
    "kernel": { "type": "string" },
    "architecture": { "type": "string" },
    "process_architecture": { "type": "string" },
    "bun_architecture": { "type": "string" },
    "node_architecture": { "type": "string" },
    "rosetta_translated": { "type": "boolean" },
    "cpu": { "type": "string" },
    "logical_cpus": { "type": "integer", "minimum": 1 },
    "memory_bytes": { "type": "integer", "minimum": 0 },
    "fs_case_sensitive": { "type": "boolean" },
    "git_version": { "type": "string" },
    "git_lfs_version": { "type": "string" },
    "bun_version": { "type": "string" },
    "bun_revision": { "type": "string" },
    "node_version": { "type": "string" },
    "npm_version": { "type": "string" },
    "vscode_version": { "type": ["string", "null"] },
    "vscode_architecture": { "type": ["string", "null"] },
    "xcode_path": { "type": ["string", "null"] },
    "xcode_version": { "type": ["string", "null"] },
    "python_version": { "type": "string" },
    "clang_version": { "type": "string" },
    "shell": { "type": "string" },
    "locale": { "type": "string" },
    "timezone": { "type": "string" },
    "proxy_variable_names": { "type": "array", "items": { "type": "string" } },
    "ci_indicator": { "type": "boolean" },
    "native_assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uname_m", "process_arch", "bun_arch", "node_arch", "rosetta_disabled", "all_pass"],
      "properties": {
        "uname_m": { "type": "string" },
        "process_arch": { "type": "string" },
        "bun_arch": { "type": "string" },
        "node_arch": { "type": "string" },
        "rosetta_disabled": { "type": "boolean" },
        "all_pass": { "type": "boolean" }
      }
    }
  }
}